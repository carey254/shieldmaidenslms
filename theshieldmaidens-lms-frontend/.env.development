# Shield Maidens LMS — local development ports (not generic 5173/8000)
# Backend API (Laravel): http://127.0.0.1:8780
VITE_API_BASE_URL=http://127.0.0.1:8780/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8780

# npm run dev starts BOTH: main http://127.0.0.1:5180 and admin http://127.0.0.1:5181
# npm run dev:app = port 5180 only | npm run dev:admin = port 5181 only
