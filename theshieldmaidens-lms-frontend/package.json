{
  "name": "theshieldmaidens-lms-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n main,admin -c blue,magenta \"vite --host 127.0.0.1 --port 5180\" \"vite --host 127.0.0.1 --port 5181\"",
    "dev:app": "vite --host 127.0.0.1 --port 5180",
    "dev:admin": "vite --host 127.0.0.1 --port 5181 --open /admin/login",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5180"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  }
